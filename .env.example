# Credenciales de Supabase — cópialo a .env.local y rellena con tus valores.
# (.env.local NO se sube a git; estas son variables públicas del cliente.)

# Supabase > Project Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co

# Supabase > Project Settings > API > anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Clave simple que desbloquea el modo edición en la interfaz.
# Inventa la que quieras; compártela solo con quien deba editar.
NEXT_PUBLIC_EDIT_KEY=cambia-esta-clave
